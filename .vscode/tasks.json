{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                "${workspaceFolder}",
                "-B",
                "${workspaceFolder}/build",
                "-DMPCNS_ENABLE_METIS=OFF",
                "-DMPCNS_ENABLE_MPI=OFF",
                "-DMPCNS_ENABLE_WINDOWS_SAFE_COUT=OFF"
            ],
            "problemMatcher": []
        },
        {
            "label": "CMake: build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "-j",
                "2"
            ],
            "dependsOn": "CMake: configure",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Run MAIN",
            "type": "shell",
            "command": "${workspaceFolder}/build/MAIN",
            "dependsOn": "CMake: build",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        }
    ]
}
